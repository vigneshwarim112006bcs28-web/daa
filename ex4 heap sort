#include <iostream>

using namespace std;

void printArray(int arr[], int n) {
    for (int i = 0; i < n; i++) cout << arr[i] << " ";
    cout << endl;
}

void percolateDown(int arr[], int n, int i) {
    int smallest = i;
    int left = 2 * i + 1;
    int right = 2 * i + 2;


    if (left < n && arr[left] < arr[smallest])
        smallest = left;


    if (right < n && arr[right] < arr[smallest])
        smallest = right;


    if (smallest != i) {
        int temp = arr[i];
        arr[i] = arr[smallest];
        arr[smallest] = temp;
        percolateDown(arr, n, smallest);
    }
}

int main() {
    int n;
    cout << "Enter number of keys: ";
    cin >> n;

    int arr[100];


    cout << "\n--- STAGE 1: Top-to-Bottom Insertion ---" << endl;
    for (int i = 0; i < n; i++) {
        cout << "Enter element " << i + 1 << ": ";
        cin >> arr[i];
    }
    cout << "Initial Tree (Level-Order): ";
    printArray(arr, n);


    cout << "\n--- STAGE 1: Percolating Down to Build Min-Heap ---" << endl;
    for (int i = n / 2 - 1; i >= 0; i--) {
        percolateDown(arr, n, i);
        cout << "After percolating index " << i << ": ";
        printArray(arr, n);
    }


    cout << "\n--- STAGE 2: Repeatedly Deleting Min (Sorting) ---" << endl;
    for (int i = n - 1; i > 0; i--) {

        int temp = arr[0];
        arr[0] = arr[i];
        arr[i] = temp;

        cout << "Extracted Min [" << temp << "]. New root: [" << arr[0] << "]" << endl;


        percolateDown(arr, i, 0);
        cout << "Heap after percolating down: ";
        printArray(arr, i);
        cout << "---------------------------------------" << endl;
    }


    cout << "\nFinal Array (Descending Order via Min-Heap): ";
    printArray(arr, n);

    return 0;
}
