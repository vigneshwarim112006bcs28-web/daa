#include <iostream>
#include <vector>
#include <queue>
#include <algorithm>

using namespace std;

// Structure to hold Item details
struct Item {
    int value, weight, originalId;
};

// Structure for Branch and Bound tree nodes
struct Node {
    int level;
    int profit;
    int weight;
    float bound;
    vector<int> contains; // List of items included in this path
};

// Sort items by density (Value/Weight)
bool compareByDensity(Item a, Item b) {
    return (float)a.value / a.weight > (float)b.value / b.weight;
}

// Priority Queue needs to pick node with highest bound
struct CompareBound {
    bool operator()(const Node& a, const Node& b) {
        return a.bound < b.bound;
    }
};

// Calculate the maximum possible profit (Upper Bound)
float calculateBound(Node u, int n, int W, const vector<Item>& items) {
    if (u.weight >= W) return 0;
    float profit_bound = (float)u.profit;
    int j = u.level + 1;
    int total_weight = u.weight;

    while (j < n && total_weight + items[j].weight <= W) {
        total_weight += items[j].weight;
        profit_bound += items[j].value;
        j++;
    }

    if (j < n)
        profit_bound += (W - total_weight) * ((float)items[j].value / items[j].weight);

    return profit_bound;
}

int main() {
    int n, W;
    cout << "--- Knapsack Branch and Bound ---\n";
    cout << "Enter number of items: ";
    cin >> n;
    cout << "Enter max capacity: ";
    cin >> W;

    vector<Item> items(n);
    for (int i = 0; i < n; i++) {
        cout << "Item " << i + 1 << " (Value Weight): ";
        cin >> items[i].value >> items[i].weight;
        items[i].originalId = i + 1;
    }

    // Sort items for greedily calculating bounds
    sort(items.begin(), items.end(), compareByDensity);

    priority_queue<Node, vector<Node>, CompareBound> pq;
    vector<int> finalItems;
    int maxProfit = 0;

    Node u;
    u.level = -1; u.profit = 0; u.weight = 0;
    u.bound = calculateBound(u, n, W, items);
    pq.push(u);

    while (!pq.empty()) {
        u = pq.top();
        pq.pop();

        if (u.bound <= maxProfit) continue;

        Node v;
        v.level = u.level + 1;

        // Path 1: Include the next item
        v.weight = u.weight + items[v.level].weight;
        v.profit = u.profit + items[v.level].value;
        v.contains = u.contains;
        v.contains.push_back(items[v.level].originalId);

        if (v.weight <= W) {
            if (v.profit > maxProfit) {
                maxProfit = v.profit;
                finalItems = v.contains;
            }
            v.bound = calculateBound(v, n, W, items);
            if (v.bound > maxProfit) pq.push(v);
        }

        // Path 2: Exclude the next item
        v.weight = u.weight;
        v.profit = u.profit;
        v.contains = u.contains;
        v.bound = calculateBound(v, n, W, items);
        if (v.bound > maxProfit) pq.push(v);
    }

    // --- Final Results Output ---
    cout << "\n===============================";
    cout << "\n       FINAL SOLUTION";
    cout << "\n===============================";
    cout << "\nMax Profit: " << maxProfit;
    cout << "\nItems Picked (IDs): ";
    if (finalItems.empty()) {
        cout << "None (Items too heavy)";
    } else {
        for (size_t i = 0; i < finalItems.size(); i++) {
            cout << finalItems[i] << " ";
        }
    }
    cout << "\n===============================\n";

    return 0;
}

