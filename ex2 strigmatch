#include <stdio.h>

int main()
{
    int text[100], pattern[50];
    int n, m;
    int i, j;
    int alignments = 0, comparisons = 0;
    int foundIndex = -1;

    printf("Enter length of text: ");
    scanf("%d", &n);

    printf("Enter text elements:\n");
    for (i = 0; i < n; i++)
        scanf("%d", &text[i]);

    printf("Enter length of pattern: ");
    scanf("%d", &m);

    printf("Enter pattern elements:\n");
    for (i = 0; i < m; i++)
        scanf("%d", &pattern[i]);

    printf("\n");

    // Brute force matching
    for (i = 0; i <= n - m; i++)
    {
        alignments++;

        // print spaces for pattern movement
        for (j = 0; j < i; j++)
            printf("  ");

        // print pattern
        for (j = 0; j < m; j++)
            printf("%d ", pattern[j]);

        printf("\n");

        // comparisons
        for (j = 0; j < m; j++)
        {
            comparisons++;
            if (text[i + j] != pattern[j])
                break;
        }

        if (j == m)
            foundIndex = i;
    }

    printf("\nNumber of alignments = %d", alignments);
    printf("\nNumber of comparisons = %d", comparisons);

    if (foundIndex != -1)
        printf("\nPattern found at index = %d", foundIndex);
    else
        printf("\nPattern not found");

    return 0;
}
