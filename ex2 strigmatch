#include <iostream>
#include <cmath>
using namespace std;
double distance(double x1, double y1, double x2, double y2)
{
    double dx = x2 - x1;
    double dy = y2 - y1;
    return sqrt(dx*dx + dy*dy);
}
void findClosest(double x[], double y[], int n)
{
    double minDist = 999999;
    int p1 = 0, p2 = 1;

    cout << "\nDistances between each pair:\n";

    for (int i = 0; i < n; i++)
    {
        for (int j = i + 1; j < n; j++)
        {
            double d = distance(x[i], y[i], x[j], y[j]);

            cout << "(" << x[i] << "," << y[i] << ") - ("
                 << x[j] << "," << y[j] << ") = " << d << endl;

            if (d < minDist)
            {
                minDist = d;
                p1 = i;
                p2 = j;
            }
        }
    }

    cout << "\nClosest Pair: (" << x[p1] << "," << y[p1] << ") and ("
         << x[p2] << "," << y[p2] << ")";
    cout << "\nMinimum Distance = " << minDist << endl;
}

int main()
{
    int n;
    cout << "Enter points: ";
    cin >> n;

    double x[n], y[n];

    cout << "Enter coordinates of x,y:\n";
    for (int i = 0; i < n; i++)
    {
        cin >> x[i] >> y[i];
    }

    findClosest(x, y, n);

    return 0;
}
